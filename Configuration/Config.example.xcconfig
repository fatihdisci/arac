// Garajım — Configuration Template
// Copy this file to Config.xcconfig and fill in real values.
// Config.xcconfig is gitignored — never commit production secrets.

// Supabase project URL (https://YOUR-PROJECT.supabase.co)
SUPABASE_URL = https://YOUR-PROJECT.supabase.co

// Supabase anonymous key (public, RLS-enforced)
SUPABASE_ANON_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

// Swift Compiler — Custom Flags for Info.plist preprocessor
// These are set via Xcode build settings, not here directly.
// The xcconfig values are read via Bundle.main.infoDictionary
// using the key format SUPABASE_URL and SUPABASE_ANON_KEY.
//
// In Xcode build settings, add to "Preprocessor Definitions" or
// "Active Compilation Conditions": none needed.
// Values are loaded from Info.plist which is populated via
// Xcode's "Info.plist Values" section from xcconfig vars.
